# Model artifacts
models/
**/models/
swell/resources/models/
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx
# Keep shared Python model-state package tracked (code only, not weights)
!swell/shared/models/
!swell/shared/models/__init__.py
!swell/shared/models/state.py

# Third-party updater runtimes are provisioned locally for release builds.
swell/resources/updater/macos/Sparkle.framework/
swell/resources/updater/macos/bin/
swell/resources/updater/windows/*.dll

# Local shell/history
.Rhistory
