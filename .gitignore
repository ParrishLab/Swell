*.log
*.tmp
.tmp/
.cache/
**/.cache/

# Jupyter
.ipynb_checkpoints/

# App runtime outputs
/config.json
output/
**/output/
metrics_analysis/
**/metrics_analysis/
autosaves/
**/autosaves/
*.sdproj.tmp
